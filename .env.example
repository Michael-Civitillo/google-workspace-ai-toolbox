# --- Required ---

# Password for the toolbox UI. The app refuses to start mutating actions if
# this is unset, so it can never be deployed wide-open by accident.
APP_PASSWORD=change-me-to-something-long-and-random

# --- Workspace credentials (used as fallback if no tenant is selected) ---

# Google Workspace CLI — absolute path to your service account JSON key.
# Examples: /Users/me/keys/sa.json (macOS/Linux) or C:\creds\sa.json (Windows)
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/path/to/service-account.json

# Optional: override the gws binary resolution. Defaults to "gws" (or
# "gws.cmd" on Windows). Set this if you installed gws via a non-PATH
# location or as gws.exe.
# GWS_BIN=C:\path\to\gws.exe

# Admin email for impersonation (needed for Domain Change feature)
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@yourdomain.com

# --- AI ---

# Gemini API key for AI features (get one at https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
