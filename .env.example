# Google Workspace CLI — path to your service account JSON key
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/path/to/service-account.json

# Admin email for impersonation (needed for Domain Change feature)
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@yourdomain.com

# Gemini API key for AI features (get one at https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
