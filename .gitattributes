# Default: normalise line endings to LF on commit, check out as LF.
# Keeps CRLF/LF noise out of diffs when Windows and macOS/Linux contributors
# touch the same files.
* text=auto eol=lf

# Binary assets — never normalise.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    text eol=lf
*.pdf    binary
*.zip    binary

# Lockfiles — keep LF.
package-lock.json text eol=lf
yarn.lock         text eol=lf

# Shell scripts must stay LF even on Windows checkouts (cmd shims tolerate
# LF; bash refuses CRLF).
*.sh  text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.js  text eol=lf
*.ts  text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md  text eol=lf
